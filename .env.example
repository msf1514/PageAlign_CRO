# ─── Gemini (required) ───────────────────────────────────────────────────────
# Provide one OR several comma-separated keys. With multiple keys the CRO engine
# rotates to the next key on rate-limit / quota errors (helpful for free tiers,
# since each run makes 5–10 sequential Gemini calls).
GEMINI_API_KEYS=your_gemini_key_1,your_gemini_key_2,your_gemini_key_3

# Legacy single-key names are still honored (precedence: EXTERNAL_GEMINI_API_KEYS
# > GEMINI_API_KEYS > EXTERNAL_GEMINI_API_KEY > GEMINI_API_KEY):
# GEMINI_API_KEY=
# EXTERNAL_GEMINI_API_KEY=

# Optional: override the Gemini model id (defaults to gemini-3.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# ─── OpenRouter fallback (optional — free models) ────────────────────────────
# When Gemini is overloaded (503) / rate-limited, the engine falls back to
# OpenRouter free models so the site keeps working. Get a free key at
# https://openrouter.ai/keys . Provide one or several (comma-separated).
OPENROUTER_API_KEY=
# OPENROUTER_API_KEYS=key1,key2

# Free models to try, in order. VERIFY current free models at
# https://openrouter.ai/models?max_price=0 (availability changes). The first
# should ideally support vision (for ad-screenshot input) + JSON output.
# OPENROUTER_MODELS=google/gemini-2.0-flash-exp:free,meta-llama/llama-3.3-70b-instruct:free,deepseek/deepseek-chat-v3-0324:free

# Provider priority (default: gemini first, then openrouter).
# LLM_PROVIDER_PRIORITY=gemini,openrouter

# ─── Firecrawl (optional) ──────────────────────────────────────────────────────
# Enables live page scraping (v1 API). Without it, an AI-generated mock page
# blueprint is used instead.
FIRECRAWL_API_KEY=

# ─── Supabase (optional — enables accounts + saved runs) ─────────────────────
# Project Settings → API. The anon/publishable key is safe in the browser.
# Without these, the app still works but runs aren't saved (auth UI hides).
# Run supabase/schema.sql in your project to create the cro_runs table.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_publishable_key

# ─── Misc ──────────────────────────────────────────────────────────────────────
APP_URL=
